# Copy this file to .env.makefile and adjust values for your environment.
# Do not commit .env.makefile with real credentials or private hosts.

KUBE_CONTEXT=CHANGE_ME_KUBE_CONTEXT
LOCAL_API_IMAGE=example/api-manager:local
LOCAL_APP_IMAGE=example/app-cliente:local
LOCAL_API_URL=http://api.example.com

VPS_API_IMAGE=ghcr.io/change-me-owner/change-me-repo-api-manager:latest
VPS_APP_IMAGE=ghcr.io/change-me-owner/change-me-repo-app-cliente:latest
VPS_EVOLUTION_IMAGE=evoapicloud/evolution-api:latest

SERVER=CHANGE_ME_USER@CHANGE_ME_HOST
PROJECT_PATH=kubernetes_deploy
REMOTE_DIR=~/kubernetes_deploy
USER_DOCKER=change-me-owner

SSH=ssh
SCP=scp
RSYNC=rsync
KUBE_CONTEXT_REMOTE=$$(kubectl config current-context)
RSYNC_EXCLUDES=--exclude=.git --exclude=node_modules --exclude=app_cliente/build --exclude=evolution-api/node_modules
